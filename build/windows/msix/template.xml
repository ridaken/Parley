<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="parley.exe"
        Arguments=""
        InstallLocation="C:\Program Files\Vokac\Parley">
    </Installer>
    <PackageInformation
        PackageName="Parley"
        PackageDisplayName="Parley"
        PublisherName="CN=Vokac"
        PublisherDisplayName="Vokac"
        Version="0.1.0.0"
        PackageDescription="Local-first meeting assistant">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="dev.vokac.parley"
                Description="Local-first meeting assistant"
                DisplayName="Parley"
                ExecutableName="parley.exe"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>Parley</DisplayName>
            <PublisherDisplayName>Vokac</PublisherDisplayName>
            <Description>Local-first meeting assistant</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="parley.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
